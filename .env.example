# EduChat Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# RENDER DEPLOYMENT (Backend)
# ============================================
# PostgreSQL connection string from Render
# Format: postgres://user:password@host:port/database
DATABASE_URL=

# ============================================
# API KEYS (At least one required)
# ============================================
# Google Gemini API - Free tier available
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq API - Fast free tier
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter API - Access to many models
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI API (optional)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API (optional)
# Get from: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=

# ============================================
# VERCEL DEPLOYMENT (Frontend)
# ============================================
# Your Render backend URL (without trailing slash)
# Example: https://educhat-api.onrender.com
VITE_API_URL=http://localhost:8000
